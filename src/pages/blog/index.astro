---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Section from '../../components/Section.astro'
import PostCard from '../../components/PostCard.astro'
import { getPublishedPosts } from '../../data/posts.js'
import '../../styles/prose.css'

const posts = await getPublishedPosts()
---

<BaseLayout
  title="Blog — Francisco Varisco"
  description="Long-form thoughts on AI, agents and building things — written by me, delivered by no algorithm."
>
  <Section
    id="writing"
    label="Blog"
    description="Long-form thoughts on AI, agents and building things. Written by me, delivered by no algorithm."
  >
    {
      posts.length > 0 ? (
        <ul class="post-list">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </ul>
      ) : (
        <p class="section-desc">Nothing here yet — first post coming soon.</p>
      )
    }
  </Section>
</BaseLayout>
