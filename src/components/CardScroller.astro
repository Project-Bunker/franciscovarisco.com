---
const { items } = Astro.props

const isExternal = (href) => /^https?:\/\//.test(href)
---

<ul class="card-scroller">
  {
    items.map((c) => {
      const content = (
        <>
          {c.img ? (
            <img
              class="scroll-card-media"
              src={c.img}
              alt=""
              style={c.imgPos ? { 'object-position': c.imgPos } : undefined}
            />
          ) : (
            <div class="scroll-card-media" style={{ background: c.color }} />
          )}
          {c.href && isExternal(c.href) && (
            <span class="scroll-card-arrow">↗</span>
          )}
          <div class="scroll-card-body">
            <h3 class="scroll-card-title">{c.title}</h3>
            <p class="scroll-card-blurb">{c.blurb}</p>
          </div>
        </>
      )
      return (
        <li class="scroll-card">
          {c.href ? (
            <a
              class="scroll-card-link"
              href={c.href}
              {...(isExternal(c.href) && {
                target: '_blank',
                rel: 'noreferrer',
              })}
            >
              {content}
            </a>
          ) : (
            content
          )}
        </li>
      )
    })
  }
</ul>
